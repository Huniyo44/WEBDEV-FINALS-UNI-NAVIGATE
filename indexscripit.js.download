 const cardsContainer = document.getElementById('cardsContainer');
        const menuItems = document.querySelectorAll('.menu-item');

        // Filtering logic
        menuItems.forEach(button => {
            button.addEventListener('click', () => {
                document.querySelector('.menu-item.active').classList.remove('active');
                button.classList.add('active');
                const category = button.dataset.category;
                const hero = document.querySelector('.hero');
                const aboutSection = document.querySelector('.about-section');
                const cardsContainer = document.querySelector('.cards');
                const header = document.querySelector('.header');
                const developers = document.querySelector('.developers');
                const footer = document.querySelector('.footer');
                const role = getUserRole();
                if (category === 'home') {
                    hero.style.display = 'block';
                    aboutSection.style.display = 'none';
                    cardsContainer.style.display = 'none';
                    header.style.display = 'none';
                    developers.style.display = 'block';
                    footer.style.display = 'block';
                    if (role && userPanel) {
                        userPanel.classList.remove('hidden');
                    }
                } else if (category === 'snacks') {
                    hero.style.display = 'none';
                    aboutSection.style.display = 'block';
                    cardsContainer.style.display = 'none';
                    header.style.display = 'block';
                    developers.style.display = 'none';
                    footer.style.display = 'none';
                    if (userPanel) {
                        userPanel.classList.add('hidden');
                    }
                } else {
                    hero.style.display = 'none';
                    aboutSection.style.display = 'none';
                    cardsContainer.style.display = 'flex';
                    header.style.display = 'block';
                    developers.style.display = 'none';
                    footer.style.display = 'none';
                    if (userPanel) {
                        userPanel.classList.add('hidden');
                    }
                    document.querySelectorAll('.meal-card').forEach(card => {
                        card.style.display = (category === 'all' || card.dataset.category === category) ? 'block' : 'none';
                    });
                }
            });
        });

        // Initial state
        const initialActive = document.querySelector('.menu-item.active');
        const aboutSection = document.querySelector('.about-section');
        if (initialActive && initialActive.dataset.category === 'home') {
            document.querySelector('.hero').style.display = 'block';
            aboutSection.style.display = 'none';
            document.querySelector('.cards').style.display = 'none';
            document.querySelector('.header').style.display = 'none';
            const developers = document.querySelector('.developers');
            const footer = document.querySelector('.footer');
            if (developers) developers.style.display = 'block';
            if (footer) footer.style.display = 'block';
        }

        const openLoginBtn = document.getElementById('openLogin');
        const accountBtn = document.getElementById('accountBtn');
        const rightDrawer = document.getElementById('rightDrawer');
        const drawerBackdrop = document.getElementById('drawerBackdrop');
        const closeDrawer = document.getElementById('closeDrawer');
        const loginForm = document.getElementById('loginForm');
        const userPanel = document.getElementById('userPanel');
        const roleNameEl = document.getElementById('roleName');
        const userNameEl = document.getElementById('userName');
        const logoutBtn = document.getElementById('logoutBtn');
        const roleActions = document.getElementById('roleActions');

        const rolePermissions = {
            'Super Admin': [
                { title: 'Manage Users', desc: 'Create or edit admin and user accounts.', action: 'manageUsers' },
                { title: 'Site Settings', desc: 'Configure site and navigation settings.', action: 'siteSettings' }
            ],
            'Admin': [
                { title: 'Edit Buildings', desc: 'Update building information and map links.', action: 'editBuildings' },
                { title: 'Review Content', desc: 'Approve new page details and descriptions.', action: 'reviewContent' }
            ],
            'User': [
                { title: 'Explore Buildings', desc: 'Open building pages and view campus locations.', action: 'exploreBuildings' },
                { title: 'Open Map Links', desc: 'Use map links for quick navigation.', action: 'openMaps' }
            ]
        };

        const setUserRole = (role) => {
            sessionStorage.setItem('olfuRole', role);
        };

        const clearUserRole = () => {
            sessionStorage.removeItem('olfuRole');
        };

        const getUserRole = () => {
            return sessionStorage.getItem('olfuRole');
        };

        const buildRoleActions = (role) => {
            if (!roleActions) return;
            roleActions.innerHTML = '';
            const permissions = rolePermissions[role] || [];
            permissions.forEach((permission) => {
                const card = document.createElement('div');
                card.className = 'permission-card';
                card.innerHTML = `
                    <h3>${permission.title}</h3>
                    <p>${permission.desc}</p>
                    <button type="button" data-action="${permission.action}">${permission.title}</button>
                `;
                roleActions.appendChild(card);
            });
        };

        const updateRolePanel = () => {
            const role = getUserRole();
            if (!userPanel) return;
            if (!role) {
                userPanel.classList.add('hidden');
                updateSidebarButtons();
                return;
            }
            userPanel.classList.remove('hidden');
            roleNameEl.textContent = role;
            userNameEl.textContent = role === 'User' ? 'Campus Visitor' : role;
            buildRoleActions(role);
            updateSidebarButtons();
        };

        const updateSidebarButtons = () => {
            const role = getUserRole();

            if (!openLoginBtn) return;

            if (role) {
                openLoginBtn.innerHTML = '<i class="icon fas fa-sign-out-alt"></i><span class="label">Logout</span>';
                openLoginBtn.title = 'Logout';
            } else {
                openLoginBtn.innerHTML = '<i class="icon fas fa-sign-in-alt"></i><span class="label">Login</span>';
                openLoginBtn.title = 'Login';
            }
        };

        updateSidebarButtons();
        updateRolePanel();

        const drawerOpen = () => {
            rightDrawer.classList.add('open');
            drawerBackdrop.classList.add('open');
        };

        const drawerClose = () => {
            rightDrawer.classList.remove('open');
            drawerBackdrop.classList.remove('open');
        };

        openLoginBtn?.addEventListener('click', () => {
            if (getUserRole()) {
                clearUserRole();
                window.location.href = 'index.html';
                return;
            }
            drawerOpen();
        });

        accountBtn?.addEventListener('click', () => {
            if (getUserRole()) {
                userPanel?.classList.toggle('hidden');
            } else {
                drawerOpen();
            }
        });

        closeDrawer?.addEventListener('click', drawerClose);
        drawerBackdrop?.addEventListener('click', drawerClose);

        const users = [
            { email: 'super@olfu.edu', password: 'super123', role: 'Super Admin', page: 'dashboard-super-admin.html' },
            { email: 'admin@olfu.edu', password: 'admin123', role: 'Admin', page: 'dashboard-admin.html' },
            { email: 'user@olfu.edu', password: 'user123', role: 'User', page: 'dashboard-user.html' }
        ];

        loginForm?.addEventListener('submit', (event) => {
            event.preventDefault();
            const email = loginForm.email.value.trim().toLowerCase();
            const password = loginForm.password.value.trim();
            const user = users.find(u => u.email === email && u.password === password);

            if (!user) {
                alert('Invalid login. Please use one of the demo accounts shown in the drawer.');
                return;
            }

            setUserRole(user.role);
            alert(`Welcome ${user.role}! Redirecting to the home page...`);
            drawerClose();
            window.location.href = 'index.html';
        });
